# ──────────────────────────────────────────────────────────────────────────────
# Section 14 — Backplane geometry
# ──────────────────────────────────────────────────────────────────────────────
section(152, "14. Backplane geometry")
# Attachment post positions (3 pairs, integral to Platform):
#   Post pair A: Y = +39mm (battery front)
#   Post pair B: Y = -39mm (battery rear)
#   Post pair C: Y = -148mm (fan rear / backplane tail)
# Battery zone RIGHT side fully open — no lattice beam between Y=+39 and Y=-39mm.
# Fan exhaust zone (Y=-138 to -148mm): no lattice — fully open for exhaust.
var(153, "BackplaneNose",          "39.0",   "BackplaneNose",          "Backplane nose edge = battery front edge [mm]")
var(154, "BackplaneTail",          "-148.0", "BackplaneTail",          "Backplane tail edge = fan rear face [mm]")
var(155, "BackplaneLength",        "187.0",  "BackplaneLength",        "Total backplane length [mm]")
var(156, "BackplaneWidth",         "50.0",   "BackplaneWidth",         "Backplane width = PlatformWidthElec [mm]")
var(157, "BackplaneBeamWidth",     "3.0",    "BackplaneBeamWidth",     "Lattice beam width [mm]")
var(158, "BackplaneBeamThick",     "1.5",    "BackplaneBeamThick",     "Lattice beam thickness above Platform [mm]")
var(159, "BackplaneRibSpacing",    "20.0",   "BackplaneRibSpacing",    "Transverse rib centre-to-centre [mm]")
var(160, "BackplaneFill",          "35.0",   "BackplaneFill",          "Approximate material fill [%] (~65% open area)")
var(161, "BackplanePostDia",       "6.0",    "BackplanePostDia",       "Attachment post outer diameter [mm]")
var(162, "BackplanePostHeight",    "54.0",   "BackplanePostHeight",    "Post height = BattRailHeight + 1mm [mm]")
var(163, "BackplaneAttachDia",     "3.0",    "BackplaneAttachDia",     "M3 clearance hole at each post base [mm]")
var(164, "BackplaneGX12BossOD",    "18.0",   "BackplaneGX12BossOD",   "Boss ring OD around GX12 hole in lattice [mm]")
var(165, "BackplaneGX12BossThick", "3.0",    "BackplaneGX12BossThick","Boss ring wall thickness [mm]")

# ──────────────────────────────────────────────────────────────────────────────
# Section 15 — Pi bay and companion interface geometry
# ──────────────────────────────────────────────────────────────────────────────
section(167, "15. Pi bay and companion interface geometry")
# Pi bay is MANDATORY on every build across all platforms.
# Empty bay uses a printed cover plate. Pi Zero 2W installs in 15 minutes.
# CRITICAL: Pi bay raises payload mast surface by PiBayInternalHeight (6mm)
# above the Backplane surface. All mast height calculations must include this.
var(168, "PiBayInternalWidth",    "72.0",  "PiBayInternalWidth",    "Pi bay internal width [mm]")
var(169, "PiBayInternalLength",   "38.0",  "PiBayInternalLength",   "Pi bay internal length [mm]")
var(170, "PiBayInternalHeight",   "6.0",   "PiBayInternalHeight",   "Pi bay internal height — adds 6mm to payload mast height [mm]")
var(171, "PiBayWall",             "2.0",   "PiBayWall",             "Pi bay wall thickness [mm]")
var(172, "PiBayStandoffSpacingX", "58.0",  "PiBayStandoffSpacingX", "Pi Zero 2W hole spacing X axis [mm]")
var(173, "PiBayStandoffSpacingY", "23.0",  "PiBayStandoffSpacingY", "Pi Zero 2W hole spacing Y axis [mm]")
var(174, "PiBayStandoffDia",      "2.5",   "PiBayStandoffDia",      "M2.5 standoff mounting holes [mm]")
var(175, "PiBayHarnessSlot",      "8.0",   "PiBayHarnessSlot",      "JST-SH cable entry slot width [mm]")
var(176, "PiZeroWidth",           "65.0",  "PiZeroWidth",           "Pi Zero 2W PCB width reference [mm]")
var(177, "PiZeroLength",          "30.0",  "PiZeroLength",          "Pi Zero 2W PCB length reference [mm]")
var(178, "PiZeroHeight",          "5.0",   "PiZeroHeight",          "Pi Zero 2W maximum component height reference [mm]")

# ──────────────────────────────────────────────────────────────────────────────
# Finalise
# ──────────────────────────────────────────────────────────────────────────────
doc.recompute()
FreeCAD.ActiveDocument.save() if doc.FileName else None

FreeCAD.Console.PrintMessage(
    "\nLD_V300_Variables.FCMacro complete.\n"
    "Variables spreadsheet created with 15 sections.\n"
    "\nNext steps:\n"
    "  1. Double-click Variables in Model Tree to verify.\n"
    "  2. Spot-check: B2 alias = Wheelbase, B7 alias = ArmWidth.\n"
    "  3. Print Coupon 8 (T-slot), Coupon 8b (rod), Coupon 10 (GX12), Coupon 11 (battery rail).\n"
    "  4. Adjust TabWidth, RodDiaChannelCore, GX12ChimneyBoreFlatFlat, BattRailInnerWidth from coupon results.\n"
    "  5. See variable-table-values.md for full tolerances and notes.\n"
    "  Ctrl+S to save.\n"
)
