# LD_V300_Variables.FCMacro
# libdrone V3.0.0 — parametric variable table population macro
#
# Licence: CC BY-SA 4.0
# Author:  Jakub Safar (jsa)
# Corpus:  https://libdrone.eu / https://github.com/libdrone/libdrone
#
# Usage:
#   1. Open or create a FreeCAD document (.FCStd).
#   2. Copy this file to your FreeCAD Macro folder:
#        macOS:          ~/Library/Preferences/FreeCAD/Macro/
#        Linux native:   ~/.FreeCAD/Macro/
#        Linux Flatpak:  ~/.var/app/org.freecad.FreeCAD/data/FreeCAD/1.1/Macro/
#                        (confirm path via Tools → Macros)
#        Windows:        %APPDATA%\FreeCAD\Macro\
#   3. Tools → Macros → select LD_V300_Variables → Execute.
#   4. A spreadsheet named "Variables" appears in the Model Tree.
#   5. Spot-check: click cell B1 → Properties → confirm Alias shows "Wheelbase".
#   6. Ctrl+S to save.
#
# Reference articles:
#   variable-table-structure.md  — section map, alias rules, frame- vs electronics-driven
#   variable-table-values.md     — authoritative values with tolerances and notes
#   freecad-document-setup.md    — FreeCAD preferences required before running this macro
#   prep-and-parametrics.md      — Phase 0 build workflow
#   coupon-validation.md         — coupons that must be printed before full production
#
# After running this macro, verify the following before printing any part:
#   Coupon 8   — T-slot fit         → may require TabWidth or TabClearance adjustment
#   Coupon 8b  — Rod interference   → may require RodDiaChannelCore adjustment
#   Coupon 10  — GX12 D-D bore      → may require GX12ChimneyBoreFlatFlat adjustment
#   Coupon 11  — Battery rail fit   → may require BattRailInnerWidth adjustment
#
# Section 8 (Battery Spoiler) is retained as a deprecated placeholder to preserve
# section numbering continuity. All Section 8 variables are empty by design.
#
# WARNING: Variable names are case-sensitive. A mismatched alias means any
# sketch referencing that variable will have an unsatisfied dimension.

import FreeCAD

doc = FreeCAD.ActiveDocument
if doc is None:
    FreeCAD.newDocument("libdrone_V300")
    doc = FreeCAD.ActiveDocument

# Remove existing Variables spreadsheet if present (allows re-run)
existing = doc.getObject("Variables")
if existing is not None:
    doc.removeObject("Variables")

sheet = doc.addObject("Spreadsheet::Sheet", "Variables")
doc.recompute()

# ──────────────────────────────────────────────────────────────────────────────
# Helper: set a cell label (col A), value (col B), alias, and optional comment
# ──────────────────────────────────────────────────────────────────────────────
def var(row, name, value, alias, comment=""):
    sheet.set("A" + str(row), name)
    sheet.set("B" + str(row), str(value))
    sheet.setAlias("B" + str(row), alias)
    if comment:
        sheet.set("C" + str(row), comment)

def section(row, title):
    sheet.set("A" + str(row), "### " + title + " ###")
    sheet.setStyle("A" + str(row), "bold")

