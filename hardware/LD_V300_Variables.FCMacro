# ──────────────────────────────────────────────────────────────────────────────
# Section 13 — Platform geometry
# ──────────────────────────────────────────────────────────────────────────────
section(130, "13. Platform geometry")
# Three-layer architecture: X body sandwich / Platform (electronics) / Backplane (payloads)
# Platform stepped width: 40mm battery+nose zone; 50mm from Y=-44mm (electronics zone).
# All Y positions measured from X body centre. Positive = nose. Negative = tail.
# CRITICAL: verify prop clearance at PlatformWidthElec before printing.
#   Motor at Y = -116.7mm -> 15.7mm clearance per side. Zero headroom.
#   If CAD reads < 15mm: reduce PlatformWidthElec from 50 to 48mm.
var(131, "PlatformLength",        "283.0",  "PlatformLength",        "Total Platform length [mm] — electronics-driven")
var(132, "PlatformWidthNarrow",   "40.0",   "PlatformWidthNarrow",   "Width — battery zone and nose [mm]")
var(133, "PlatformWidthElec",     "50.0",   "PlatformWidthElec",     "Width — electronics zone [mm] — verify prop clearance")
var(134, "PlatformStepY",         "-44.0",  "PlatformStepY",         "Y where width steps out to ElecWidth [mm]")
var(135, "PlatformThick",         "3.0",    "PlatformThick",         "Platform base plate thickness [mm]")
var(136, "PlatformNose",          "110.0",  "PlatformNose",          "Platform nose tip from body centre [mm]")
var(137, "PlatformTail",          "-173.0", "PlatformTail",          "Platform tail tip from body centre [mm]")
var(138, "PlatformAttachSpacing", "20.0",   "PlatformAttachSpacing", "M3 screw spacing Platform to X body [mm]")
var(139, "BattZoneFront",         "39.0",   "BattZoneFront",         "Battery front edge from body centre [mm]")
var(140, "BattZoneRear",          "-39.0",  "BattZoneRear",          "Battery rear edge from body centre [mm]")
var(141, "ElecZoneFront",         "-44.0",  "ElecZoneFront",         "Electronics zone front (ESC front) [mm]")
var(142, "ElecZoneRear",          "-89.0",  "ElecZoneRear",          "Electronics zone rear (ESC rear) [mm]")
var(143, "BuckZoneRear",          "-99.0",  "BuckZoneRear",          "Buck converter rear edge [mm]")
var(144, "VTXZoneFront",          "-104.0", "VTXZoneFront",          "VTX front edge [mm]")
var(145, "VTXZoneRear",           "-133.0", "VTXZoneRear",           "VTX rear edge [mm]")
var(146, "FanZoneFront",          "-138.0", "FanZoneFront",          "Fan front face [mm]")
var(147, "FanZoneRear",           "-148.0", "FanZoneRear",           "Fan rear face / exhaust point [mm]")
var(148, "AntennaPos",            "-153.0", "AntennaPos",            "ELRS antenna position from body centre [mm]")
var(149, "BracketZoneFront",      "110.0",  "BracketZoneFront",      "Camera/GPS bracket nose tip [mm]")
